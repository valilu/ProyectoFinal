# crear carpetas
 mkdir secuencias (de ahi entras a la carpeta)
#Descargar secuencias
 esearch -db nucleotide -query "Macaca[Organism] AND mitochondrion[Filter] AND complete genome"
#Contar cuántas secuencias hay en cada archivo
 grep -c "^>" macaca_mito.fasta
# unir todos los archivos
 los unes con cat  cat *_mito.fasta > todas_mito.fasta
#Alinear las secuencias
 muscle -in todas_mito.fasta -out todas_mito_alineado.fasta

